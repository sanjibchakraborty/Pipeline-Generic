# frozen_string_literal: true

default_platform(:ios)

platform :ios do
  desc "CI: keychain signing (secrets) + gym IPA for App Store / TestFlight"
  lane :staging_build do
    team_id = ENV.fetch("APPLE_TEAM_ID")
    profile_name = ENV.fetch("IOS_PROVISIONING_PROFILE_NAME")
    bundle_id = ENV.fetch("APP_IDENTIFIER")

    if ENV["GITHUB_ACTIONS"] == "true" && ENV["APP_STORE_CONNECT_KEY_ID"]
      api_key = app_store_connect_api_key(
        key_id: ENV.fetch("APP_STORE_CONNECT_KEY_ID"),
        issuer_id: ENV.fetch("APP_STORE_CONNECT_ISSUER_ID"),
        key_content: ENV.fetch("APP_STORE_CONNECT_API_KEY"),
        is_key_content_base64: false,
        duration: 1200,
        in_house: false
      )
      latest = latest_testflight_build_number(
        api_key: api_key,
        app_identifier: bundle_id,
        initial_build_number: 0
      )
      next_build = latest.to_i + 1
      increment_build_number(
        build_number: next_build.to_s,
        xcodeproj: "PipelineGeneric/PipelineGeneric.xcodeproj"
      )
      UI.success("Set CFBundleVersion to #{next_build} (latest TestFlight was #{latest.to_i})")
    end

    xcargs = {
      "CODE_SIGN_STYLE" => "Manual",
      "DEVELOPMENT_TEAM" => team_id,
      "PROVISIONING_PROFILE_SPECIFIER" => profile_name
    }
    identity = ENV["IOS_CODESIGN_IDENTITY"]
    xcargs["CODE_SIGN_IDENTITY"] = identity if identity && !identity.to_s.empty?

    gym(
      project: "PipelineGeneric/PipelineGeneric.xcodeproj",
      scheme: "PipelineGeneric",
      export_method: "app-store",
      output_directory: "build",
      output_name: "PipelineGeneric.ipa",
      clean: true,
      xcargs: xcargs,
      export_options: {
        method: "app-store",
        signingStyle: "manual",
        teamID: team_id,
        provisioningProfiles: {
          bundle_id => profile_name
        }
      }
    )
  end

  desc "Upload an existing IPA to TestFlight (ASC API key via env)"
  lane :upload_testflight_ipa do |options|
    ipa_path = options[:ipa] || ENV["IPA_PATH"]
    UI.user_error!("Missing ipa path (pass ipa: or IPA_PATH)") if ipa_path.nil? || ipa_path.to_s.empty? || !File.exist?(ipa_path)

    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("APP_STORE_CONNECT_KEY_ID"),
      issuer_id: ENV.fetch("APP_STORE_CONNECT_ISSUER_ID"),
      key_content: ENV.fetch("APP_STORE_CONNECT_API_KEY"),
      is_key_content_base64: false,
      duration: 1200,
      in_house: false
    )

    upload_to_testflight(
      api_key: api_key,
      ipa: ipa_path,
      skip_waiting_for_build_processing: true
    )
  end
end
