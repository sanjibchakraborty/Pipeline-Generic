# frozen_string_literal: true

default_platform(:ios)

platform :ios do
  desc "CI: Match (read-only) + gym IPA for App Store / TestFlight"
  lane :staging_build do
    app_store_connect_api_key(
      key_id: ENV.fetch("APP_STORE_CONNECT_KEY_ID"),
      issuer_id: ENV.fetch("APP_STORE_CONNECT_ISSUER_ID"),
      key_content: ENV.fetch("APP_STORE_CONNECT_API_KEY"),
      is_key_content_base64: false,
      duration: 1200,
      in_house: false
    )

    match(
      type: "appstore",
      readonly: true,
      app_identifier: [ENV.fetch("APP_IDENTIFIER")],
      git_url: ENV.fetch("MATCH_GIT_URL"),
      git_basic_authorization: ENV["MATCH_GIT_BASIC_AUTHORIZATION"]
    )

    gym(
      project: "PipelineTest1.xcodeproj",
      scheme: "PipelineTest1",
      export_method: "app-store",
      output_directory: "build",
      output_name: "PipelineTest1.ipa",
      clean: true
    )
  end
end
